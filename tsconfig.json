{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "app/*"
      ],
      "@components/*": [
        "app/components/*"
      ],
      "@hooks/*": [
        "app/hooks/*"
      ],
      "@services/*": [
        "app/services/*"
      ],
      "@utils/*": [
        "app/utils/*"
      ],
      "@store/*": [
        "app/store/*"
      ],
      "@config/*": [
        "config/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
